        </mxCell>
        <mxCell id="sf_step5" parent="sf1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="5. AI 分析 (可选)&lt;br&gt;• 生成专业建议&lt;br&gt;• 指出改进方向" vertex="1">
