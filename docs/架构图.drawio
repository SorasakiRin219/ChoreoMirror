          <mxGeometry height="70" width="180" x="400" y="350" as="geometry" />
        </mxCell>
        <mxCell id="ta_prep" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="预处理&lt;br&gt;fill_nan()&lt;br&gt;填充缺失值" vertex="1">
          <mxGeometry height="60" width="140" x="450" y="100" as="geometry" />
        </mxCell>
        <mxCell id="ta_align" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="两阶段对齐&lt;br&gt;best_align_joint()" vertex="1">
          <mxGeometry height="100" width="160" x="450" y="190" as="geometry" />
        </mxCell>
        <mxCell id="ta_stage1" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="阶段一：滑动窗口&lt;br&gt;找最优起始偏移" vertex="1">
          <mxGeometry height="40" width="140" x="460" y="200" as="geometry" />
        </mxCell>
        <mxCell id="ta_stage2" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="阶段二：DTW&lt;br&gt;规整路径采样" vertex="1">
          <mxGeometry height="40" width="140" x="460" y="240" as="geometry" />
        </mxCell>
        <mxCell id="ta_seg" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="分段差异&lt;br&gt;segment_diff()&lt;br&gt;4 个时间窗口" vertex="1">
          <mxGeometry height="70" width="140" x="640" y="115" as="geometry" />
        </mxCell>
        <mxCell id="ta_score" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="综合评分 (加权)&lt;br&gt;S = 0.60 × r_score + 0.30 × dtw_score + 0.10 × rmsd_score&lt;br&gt;&lt;br&gt;其中：&lt;br&gt;r_score = 50 × (r + 1)&lt;br&gt;dtw_score = 100 × exp(-dtw/0.8)&lt;br&gt;rmsd_score = 100 × exp(-rmsd/25)" vertex="1">
          <mxGeometry height="240" width="160" x="640" y="215" as="geometry" />
        </mxCell>
