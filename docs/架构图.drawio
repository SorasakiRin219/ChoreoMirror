          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sf_e2" edge="1" parent="sf1" source="sf_step1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="sf_step2">
