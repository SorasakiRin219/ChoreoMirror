        <mxCell id="sf_step2" parent="sf1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="2. 姿态估计&lt;br&gt;• 提取学生骨骼序列&lt;br&gt;• 提取参考骨骼序列" vertex="1">
          <mxGeometry height="70" width="180" x="160" y="390" as="geometry" />
        </mxCell>
        <mxCell id="sf_step3" parent="sf1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="3. 对比分析&lt;br&gt;• 逐关节对比&lt;br&gt;• 时序对齐分析" vertex="1">
          <mxGeometry height="70" width="180" x="380" y="390" as="geometry" />
