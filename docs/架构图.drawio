  <diagram name="评分系统架构" id="Db_9RL4q_C5lkQ0PO4kW">
    <mxGraphModel dx="1050" dy="819" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="sa0" />
        <mxCell id="sa1" parent="sa0" />
        <mxCell id="sa_title" parent="sa1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" value="&lt;b&gt;评分系统架构 (core/scoring.py + temporal/timeseries.py)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="500" x="520" y="30" as="geometry" />
        </mxCell>
        <mxCell id="sa_input" parent="sa1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入：关节角度偏差值&lt;br&gt;d = |θ_student - θ_standard|&lt;br&gt;单位：度 (°)" vertex="1">
          <mxGeometry height="60" width="160" x="20" y="310" as="geometry" />
        </mxCell>
        <mxCell id="sa_func1" parent="sa1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="deviation_grade(d)&lt;br&gt;等级评定函数&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="220" x="250" y="80" as="geometry" />
        </mxCell>
        <mxCell id="sa_formula1" parent="sa1" style="text;html=1;strokeColor=#b85450;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" value="if d ≤ 5°:        grade = excellent&lt;br&gt;if 5° &amp;lt; d ≤ 15°:  grade = good&lt;br&gt;if 15° &amp;lt; d ≤ 30°: grade = warning&lt;br&gt;if d &amp;gt; 30°:       grade = poor" vertex="1">
          <mxGeometry height="70" width="200" x="260" y="165" as="geometry" />
        </mxCell>
        <mxCell id="sa_func2" parent="sa1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="score_from_dev(d)&lt;br&gt;指数衰减评分函数&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="220" x="570" y="100" as="geometry" />
        </mxCell>
        <mxCell id="sa_formula2" parent="sa1" style="text;html=1;strokeColor=#9673a6;fillColor=#fff2cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" value="score = 100 × exp(-d/τ)&lt;br&gt;&lt;br&gt;τ = 25° (时间常数)&lt;br&gt;&lt;br&gt;特性：&lt;br&gt;d=0°   → 100 分&lt;br&gt;d=25°  → 36.8 分 (1/e)&lt;br&gt;d=50°  → 13.5 分 (1/e²)" vertex="1">
          <mxGeometry height="100" width="200" x="580" y="175" as="geometry" />
        </mxCell>
        <mxCell id="sa_out1" parent="sa1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出 1：等级&lt;br&gt;(excellent/good/warning/poor)" vertex="1">
          <mxGeometry height="50" width="180" x="820" y="100" as="geometry" />
        </mxCell>
        <mxCell id="sa_out2" parent="sa1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出 2：评分&lt;br&gt;(0-100)" vertex="1">
          <mxGeometry height="50" width="140" x="840" y="200" as="geometry" />
        </mxCell>
        <mxCell id="sa_weighted_title" parent="sa1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" value="&lt;b&gt;【加权评分】(temporal/timeseries.py)&lt;/b&gt;" vertex="1">
          <mxGeometry height="25" width="300" x="370" y="388" as="geometry" />
        </mxCell>
        <mxCell id="sa_weighted_formula" parent="sa1" style="text;html=1;strokeColor=#9673a6;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;fontStyle=1" value="S = 0.60 × r_score + 0.30 × dtw_score + 0.10 × rmsd_score&lt;br&gt;&lt;br&gt;【r_score：形态相似度】&lt;br&gt;• 含义：衡量学生与参考动作的运动轨迹形状是否一致&lt;br&gt;• Z-score 标准化：z(x) = (x - x̄) / σ，去除均值与尺度&lt;br&gt;• Pearson 相关系数：r = Σ((xᵢ - x̄)(yᵢ - ȳ)) / √(Σ(xᵢ - x̄)² × Σ(yᵢ - ȳ)²)&lt;br&gt;• 转换：r_score = 50 × (r + 1)，将 [-1, 1] 映射到 [0, 100]&lt;br&gt;• 意义：r=1 完全同步，r=-1 完全相反&lt;br&gt;&lt;br&gt;【dtw_score：时序对齐质量】&lt;br&gt;• 含义：衡量两个动作序列在时间轴上的对齐程度&lt;br&gt;• 代价矩阵：D[i,j] = (a[i] - b[j])² + min{D[i-1,j], D[i,j-1], D[i-1,j-1]}&lt;br&gt;• 归一化距离：dtw = D[n-1,m-1] / (n + m)&lt;br&gt;• 转换：dtw_score = 100 × exp(-dtw/0.8)&lt;br&gt;• 意义：距离越小得分越高，反映节奏匹配度&lt;br&gt;&lt;br&gt;【rmsd_score：角度偏差】&lt;br&gt;• 含义：衡量关节角度的平均偏差幅度&lt;br&gt;• 计算：rmsd = √(Σ(aᵢ - bᵢ)² / n)，单位：度&lt;br&gt;• 转换：rmsd_score = 100 × exp(-rmsd/25°)&lt;br&gt;• 意义：偏差越小得分越高，25°为衰减常数" vertex="1">
          <mxGeometry height="257" width="340" x="200" y="413" as="geometry" />
        </mxCell>
        <mxCell id="sa_weighted_note" parent="sa1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" value="设计原理：&lt;br&gt;• 60% 相关性：强调动作形态相似度&lt;br&gt;• 30% DTW：考虑时序对齐质量&lt;br&gt;• 10% RMSD：弱化绝对角度误差惩罚" vertex="1">
          <mxGeometry height="60" width="350" x="550" y="490" as="geometry" />
        </mxCell>
        <mxCell id="sa_e1" edge="1" parent="sa1" source="sa_input" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="sa_func1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa_e2" edge="1" parent="sa1" source="sa_input" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="sa_func2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="340" />
              <mxPoint x="540" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="sa_e3" edge="1" parent="sa1" source="sa_func1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="sa_out1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="170" />
              <mxPoint x="540" y="70" />
              <mxPoint x="910" y="70" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="sa_e4" edge="1" parent="sa1" source="sa_func2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="sa_out2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa_note" parent="sa1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" value="&lt;b&gt;评分说明：&lt;/b&gt;&lt;br&gt;• 等级评定用于快速判断动作质量&lt;br&gt;• 指数衰减公式确保小偏差获得高分奖励&lt;br&gt;• 两函数配合使用，提供完整评价" vertex="1">
          <mxGeometry height="60" width="220" x="820" y="290" as="geometry" />
        </mxCell>
        <mxCell id="3I79ouO1QFhC_92RuL7g-0" edge="1" parent="sa1" source="sa_func1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;" target="sa_func1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="3I79ouO1QFhC_92RuL7g-1" edge="1" parent="sa1" source="sa_func1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" target="sa_func1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="390" y="20" />
              <mxPoint x="515" y="20" />
              <mxPoint x="515" y="290" />
              <mxPoint x="390" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="对比分析架构" id="7wISkBHixGG5t7cAacBR">
    <mxGraphModel dx="1201" dy="819" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="ca0" />
        <mxCell id="ca1" parent="ca0" />
        <mxCell id="ca_title" parent="ca1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" value="&lt;b&gt;对比分析架构 (core/comparison.py)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="500" x="180" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ca_in_a" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 A：学生关节角度&lt;br&gt;θ_A = {joint₁, joint₂, ...}" vertex="1">
          <mxGeometry height="60" width="160" x="50" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ca_in_b" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 B：参考关节角度&lt;br&gt;θ_B = {joint₁, joint₂, ...}" vertex="1">
          <mxGeometry height="60" width="160" x="50" y="200" as="geometry" />
        </mxCell>
        <mxCell id="ca_func" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="compare_sides(θ_A, θ_B)&lt;br&gt;逐关节对比函数" vertex="1">
          <mxGeometry height="60" width="180" x="250" y="150" as="geometry" />
        </mxCell>
        <mxCell id="ca_loop" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="for joint in joints:" vertex="1">
          <mxGeometry height="40" width="140" x="460" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ca_calc1" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="偏差计算&lt;br&gt;d_j = |θ_j(A) - θ_j(B)|" vertex="1">
          <mxGeometry height="50" width="140" x="460" y="180" as="geometry" />
        </mxCell>
        <mxCell id="ca_calc2" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="评分计算&lt;br&gt;s_j = 100 × exp(-d_j/25)" vertex="1">
          <mxGeometry height="50" width="140" x="460" y="250" as="geometry" />
        </mxCell>
        <mxCell id="ca_calc3" parent="ca1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="等级评定&lt;br&gt;g_j = deviation_grade(d_j)" vertex="1">
          <mxGeometry height="50" width="140" x="460" y="320" as="geometry" />
        </mxCell>
