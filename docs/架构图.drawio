        <mxCell id="sf_step4" parent="sf1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="4. 评分计算&lt;br&gt;• 形态相似度 60%&lt;br&gt;• 时序对齐 30%&lt;br&gt;• 角度偏差 10%" vertex="1">
