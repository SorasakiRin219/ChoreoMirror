          <mxGeometry height="30" width="600" x="400" y="20" as="geometry" />
        </mxCell>
        <mxCell id="ta_in1" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 A：学生历史&lt;br&gt;hist_a = [&lt;br&gt;  {&#39;angles&#39;: {...}, &#39;t&#39;: ...},&lt;br&gt;  ...&lt;br&gt;]" vertex="1">
          <mxGeometry height="70" width="150" x="190" y="305" as="geometry" />
        </mxCell>
        <mxCell id="ta_in2" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 B：参考历史&lt;br&gt;hist_b = [&lt;br&gt;  {&#39;angles&#39;: {...}, &#39;t&#39;: ...},&lt;br&gt;  ...&lt;br&gt;]" vertex="1">
          <mxGeometry height="70" width="150" x="190" y="395" as="geometry" />
