        <mxCell id="ta_out2" parent="ta1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="部位级评分&lt;br&gt;上身/核心/下肢&lt;br&gt;综合相似度" vertex="1">
