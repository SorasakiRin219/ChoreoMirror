  <diagram name="DTW 时序规整算法" id="dtw_algo">
    <mxGraphModel dx="1050" dy="819" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="dtw0" />
        <mxCell id="dtw1" parent="dtw0" />
        <mxCell id="dtw_title" parent="dtw1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" value="&lt;b&gt;DTW 时序规整算法 (temporal/dtw.py)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="500" x="250" y="80" as="geometry" />
        </mxCell>
        <mxCell id="dtw_in1" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 A：序列 a&lt;br&gt;shape: (na,)" vertex="1">
          <mxGeometry height="50" width="140" x="50" y="150" as="geometry" />
        </mxCell>
        <mxCell id="dtw_in2" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 B：序列 b&lt;br&gt;shape: (nb,)" vertex="1">
          <mxGeometry height="50" width="140" x="50" y="220" as="geometry" />
        </mxCell>
        <mxCell id="dtw_func" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="dtw_path(a, b, band_frac=0.3)&lt;br&gt;完整 DTW 算法" vertex="1">
          <mxGeometry height="70" width="180" x="240" y="175" as="geometry" />
        </mxCell>
        <mxCell id="dtw_param" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="参数：&lt;br&gt;band_frac = 0.3&lt;br&gt;(Sakoe-Chiba 带宽)" vertex="1">
          <mxGeometry height="60" width="140" x="240" y="260" as="geometry" />
        </mxCell>
        <mxCell id="dtw_dp" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="前向 DP&lt;br&gt;计算累积代价矩阵 D&lt;br&gt;&lt;br&gt;D[i,j] = cost + min(D[i-1,j], D[i,j-1], D[i-1,j-1])" vertex="1">
          <mxGeometry height="100" width="160" x="460" y="150" as="geometry" />
        </mxCell>
        <mxCell id="dtw_cost" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="代价函数&lt;br&gt;cost = (a[i] - b[j])²" vertex="1">
          <mxGeometry height="60" width="140" x="700" y="320" as="geometry" />
        </mxCell>
        <mxCell id="dtw_back" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="回溯&lt;br&gt;从 D[na-1, nb-1] 到 D[0,0]&lt;br&gt;得到规整路径" vertex="1">
          <mxGeometry height="80" width="140" x="460" y="270" as="geometry" />
        </mxCell>
        <mxCell id="dtw_sample" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="等密度采样&lt;br&gt;N_PATH = 200&lt;br&gt;沿路径均匀采样" vertex="1">
          <mxGeometry height="70" width="140" x="360" y="410" as="geometry" />
        </mxCell>
        <mxCell id="dtw_out1" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出：归一化距离&lt;br&gt;dist = D[na-1, nb-1] / (na + nb)" vertex="1">
          <mxGeometry height="60" width="160" x="700" y="460" as="geometry" />
        </mxCell>
        <mxCell id="dtw_out2" parent="dtw1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出：规整路径&lt;br&gt;path_i: A 的帧索引数组&lt;br&gt;path_j: B 的帧索引数组&lt;br&gt;length = 200" vertex="1">
          <mxGeometry height="80" width="160" x="360" y="540" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e1" edge="1" parent="dtw1" source="dtw_in1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" target="dtw_func">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e2" edge="1" parent="dtw1" source="dtw_in2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" target="dtw_func">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e3" edge="1" parent="dtw1" source="dtw_func" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="dtw_dp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e4" edge="1" parent="dtw1" source="dtw_dp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="dtw_cost">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e5" edge="1" parent="dtw1" source="dtw_dp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="dtw_back">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e6" edge="1" parent="dtw1" source="dtw_back" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="dtw_sample">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_e7" edge="1" parent="dtw1" source="dtw_dp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="dtw_out1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="175" />
              <mxPoint x="650" y="490" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="dtw_e8" edge="1" parent="dtw1" source="dtw_sample" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="dtw_out2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dtw_note" parent="dtw1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" value="&lt;b&gt;说明：&lt;/b&gt;&lt;br&gt;• 允许长度不同的序列对齐&lt;br&gt;• Sakoe-Chiba 带宽限制搜索空间&lt;br&gt;• 等密度采样保证输出长度固定" vertex="1">
          <mxGeometry height="60" width="220" x="710" y="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="全局对齐算法" id="global_align">
    <mxGraphModel dx="1400" dy="1092" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="ga0" />
        <mxCell id="ga1" parent="ga0" />
        <mxCell id="ga_title" parent="ga1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" value="&lt;b&gt;全局对齐算法 (temporal/alignment.py)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="500" x="90" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ga_in1" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 A：学生历史&lt;br&gt;hist_a = [&lt;br&gt;  {&#39;angles&#39;: {...}, &#39;t&#39;: ...},&lt;br&gt;  ...&lt;br&gt;]" vertex="1">
          <mxGeometry height="70" width="150" x="50" y="100" as="geometry" />
        </mxCell>
        <mxCell id="ga_in2" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="输入 B：参考历史&lt;br&gt;hist_b = [&lt;br&gt;  {&#39;angles&#39;: {...}, &#39;t&#39;: ...},&lt;br&gt;  ...&lt;br&gt;]" vertex="1">
          <mxGeometry height="70" width="150" x="50" y="190" as="geometry" />
        </mxCell>
        <mxCell id="ga_func" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" value="composite_global_align(hist_a, hist_b)&lt;br&gt;全局两阶段对齐" vertex="1">
          <mxGeometry height="70" width="180" x="240" y="145" as="geometry" />
        </mxCell>
        <mxCell id="ga_build" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="构建合成信号&lt;br&gt;build_composite()&lt;br&gt;&lt;br&gt;遍历所有关节 → z-score → 平均" vertex="1">
          <mxGeometry height="90" width="160" x="460" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ga_stage1" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="阶段一：滑动窗口&lt;br&gt;best_start()&lt;br&gt;&lt;br&gt;找最优起始帧 (a_off, b_off)" vertex="1">
          <mxGeometry height="100" width="160" x="280" y="260" as="geometry" />
        </mxCell>
        <mxCell id="ga_stage2" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" value="阶段二：DTW 规整&lt;br&gt;dtw_path()&lt;br&gt;&lt;br&gt;得到分段速度归一的路径" vertex="1">
          <mxGeometry height="100" width="160" x="460" y="260" as="geometry" />
        </mxCell>
        <mxCell id="ga_map" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="帧映射&lt;br&gt;original_A_frame[k] = a_off + path_i[k]&lt;br&gt;original_B_frame[k] = b_off + path_j[k]" vertex="1">
          <mxGeometry height="80" width="160" x="260" y="450" as="geometry" />
        </mxCell>
        <mxCell id="ga_out1" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出：frame_a&lt;br&gt;长度 N_PATH=200&lt;br&gt;每个元素是 hist_a 的帧索引" vertex="1">
          <mxGeometry height="70" width="160" x="500" y="410" as="geometry" />
        </mxCell>
        <mxCell id="ga_out2" parent="ga1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="输出：frame_b&lt;br&gt;长度 N_PATH=200&lt;br&gt;每个元素是 hist_b 的帧索引" vertex="1">
          <mxGeometry height="70" width="160" x="500" y="500" as="geometry" />
        </mxCell>
        <mxCell id="ga_e1" edge="1" parent="ga1" source="ga_in1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" target="ga_func">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e2" edge="1" parent="ga1" source="ga_in2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" target="ga_func">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e3" edge="1" parent="ga1" source="ga_func" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_build">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e4" edge="1" parent="ga1" source="ga_build" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_stage1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e5" edge="1" parent="ga1" source="ga_stage1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_stage2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e6" edge="1" parent="ga1" source="ga_stage2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_map">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e7" edge="1" parent="ga1" source="ga_map" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_out1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_e8" edge="1" parent="ga1" source="ga_map" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="ga_out2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ga_note" parent="ga1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" value="&lt;b&gt;说明：&lt;/b&gt;&lt;br&gt;• 作用于骨架帧映射，而非单关节&lt;br&gt;• 合成信号综合所有关节信息&lt;br&gt;• 输出可直接用于骨架对比渲染" vertex="1">
          <mxGeometry height="60" width="220" x="50" y="330" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="简化使用流程" id="simple_flow">
    <mxGraphModel dx="1050" dy="819" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="sf0" />
        <mxCell id="sf1" parent="sf0" />
        <mxCell id="sf_title" parent="sf1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" value="&lt;b&gt;简化使用流程&lt;/b&gt;" vertex="1">
