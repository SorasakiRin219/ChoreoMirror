        <mxCell id="sf_step1" parent="sf1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="1. 准备视频&lt;br&gt;• 学生动作视频&lt;br&gt;• 参考动作视频" vertex="1">
